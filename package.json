{
  "name": "cannons-and-castles",
  "version": "1.0.0",
  "private": true,
  "description": "A server-authoritative six-round Phaser castle battler for Reddit Devvit Web.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev:local": "node server.js",
    "dev": "devvit playtest r/CannonsAndCastles",
    "build": "vite build",
    "deploy": "npm run type-check && devvit upload",
    "launch": "npm run type-check && devvit publish",
    "login": "devvit login",
    "type-check": "tsc --build",
    "test": "node scripts/run-playwright.js",
    "test:devvit": "vitest run --config vitest.config.ts tests/devvit-store.test.ts tests/devvit-route.test.ts tests/game-engine.test.js",
    "test:evaluation": "node scripts/run-playwright.js evaluation.spec.js",
    "evaluate": "node scripts/evaluate.js"
  },
  "keywords": [
    "phaser",
    "socket.io",
    "multiplayer",
    "strategy-game",
    "reddit"
  ],
  "author": "Destr0yering",
  "license": "ISC",
  "homepage": "https://www.reddit.com/r/CannonsAndCastles",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Destr0yering/cannons-and-castles.git"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=22.2.0"
  },
  "dependencies": {
    "@devvit/start": "^0.13.8",
    "@devvit/web": "^0.13.8",
    "@hono/node-server": "^2.0.8",
    "@playwright/test": "^1.61.1",
    "devvit": "^0.13.8",
    "express": "^5.2.1",
    "hono": "^4.12.28",
    "phaser": "^4.2.1",
    "socket.io": "^4.8.3",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@devvit/test": "^0.13.8",
    "@types/node": "^22.19.19",
    "vite": "^8.1.3",
    "vitest": "^4.0.18"
  }
}
