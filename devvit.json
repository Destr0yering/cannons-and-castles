{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "cannons-and-castles",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "realtime": true,
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "user"
    }
  },
  "menu": {
    "items": [
      {
        "label": "Create a Cannons and Castles battle",
        "description": "Create a new two- or four-player tactical battle post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "dev": {
    "subreddit": "CannonsAndCastles"
  }
}
